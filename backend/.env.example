# ═══════════════════════════════════════════════════════════════════════════
# Gen Audius Pro — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT: Copy this file to .env and fill in your real values.
#            NEVER commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
ENV=development            # development | production
PORT=8000
WORKERS=1                  # Increase to CPU count in production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gen_audius_db
MONGO_URL=mongodb://localhost:27017

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ── AI Music Generation ───────────────────────────────────────────────────────
KIE_API_KEY=your-kie-api-key-here
MODAL_API_URL=https://dagrabastudio--gen-audius-saas-core-fastapi-app.modal.run
MODAL_API_KEY=your_modal_master_key_here

# ── AI Mastering ──────────────────────────────────────────────────────────────
MASTERCHANNEL_API_KEY=your-masterchannel-api-key-here

# ── Optional: Amazon Nova / Additional AI ─────────────────────────────────────
AMAZON_NOVA_API_KEY=
AMAZON_NOVA_REGION=us-east-1
MODAL_API_URL=https://dagrabastudio--gen-audius-saas-core-fastapi-app.modal.run
MODAL_API_KEY=ak-iS5tmkHUKb26JuYgbCCyr3
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
