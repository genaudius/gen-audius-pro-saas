services:
  frontend:
    build:
      context: ../frontend
      dockerfile: Dockerfile
      args:
        - VITE_FIREBASE_API_KEY=AIzaSyCN2Tl0D2iC8F0mFCphwQJer9CweTLmTaA
        - VITE_FIREBASE_AUTH_DOMAIN=gen-audius-pro.firebaseapp.com
        - VITE_FIREBASE_PROJECT_ID=gen-audius-pro
        - VITE_FIREBASE_STORAGE_BUCKET=gen-audius-pro.firebasestorage.app
        - VITE_FIREBASE_MESSAGING_SENDER_ID=727297288161
        - VITE_FIREBASE_APP_ID=1:727297288161:web:2ef59d14a41652a5c494a0
        - VITE_API_URL=/api
    container_name: genaudius-frontend
    restart: always
    ports:
      - "80:80"
    depends_on:
      - backend

  backend:
    build:
      context: ../backend
      dockerfile: Dockerfile
    container_name: genaudius-backend
    restart: always
    environment:
      - DATABASE_URL=postgresql://genuser:genpass@postgres:5432/genaudius
      - MONGO_URL=mongodb://mongo:27017/genaudius_mcp_memory
      - REDIS_URL=redis://redis:6379/0
      - MODAL_API_KEY=${MODAL_API_KEY}
      - MODAL_API_URL=${MODAL_API_URL}
      - GENAUDIUS_API_KEY=${GENAUDIUS_API_KEY}
    ports:
      - "127.0.0.1:8000:8000"
    depends_on:
      - postgres
      - mongo
      - redis

  postgres:
    image: postgres:15-alpine
    container_name: genaudius-db
    restart: always
    environment:
      - POSTGRES_USER=genuser
      - POSTGRES_PASSWORD=genpass
      - POSTGRES_DB=genaudius
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:5432:5432"

  mongo:
    image: mongo:6.0
    container_name: genaudius-mongo
    restart: always
    volumes:
      - mongo_data:/data/db
    ports:
      - "127.0.0.1:27017:27017"

  redis:
    image: redis:7-alpine
    container_name: genaudius-redis
    restart: always
    ports:
      - "127.0.0.1:6379:6379"

  tunnel:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared-tunnel
    restart: always
    command: tunnel run --url http://frontend:80
    environment:
      - TUNNEL_TOKEN=${TUNNEL_TOKEN}
    depends_on:
      - frontend

volumes:
  postgres_data:
  mongo_data:
